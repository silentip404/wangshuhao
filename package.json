{
  "name": "wangshuhao",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "imports": {
    "#lib/utilities/*": "./lib/utilities/*",
    "#node/ts-expect-error-reasons.ts": "./ts-expect-error-reasons.ts",
    "#node/utilities/*": "./node/utilities/*",
    "#node/eslint-config/command/setup.ts": "./node/eslint-config/command/setup.ts",
    "#node/eslint-config/local-plugins/setup.ts": "./node/eslint-config/local-plugins/setup.ts",
    "#node/eslint-config/overrides/*": "./node/eslint-config/overrides/*",
    "#node/eslint-config/presets/*": "./node/eslint-config/presets/*",
    "#node/eslint-config/utilities/*": "./node/eslint-config/utilities/*"
  },
  "engines": {
    "node": "24.11.0",
    "pnpm": ">=10"
  },
  "volta": {
    "node": "24.11.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "run-s prepare:* --silent",
    "prepare:husky": "husky",
    "prepare:generate-commitlint-config": "pnpm exec node node/scripts/generate-commitlint-config.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "run-s lint:*",
    "lint:node-runtime-imports": "pnpm exec node node/scripts/verify-node-runtime-imports.ts",
    "lint:lockfile": "pnpm exec node node/scripts/verify-lockfile-sync.ts",
    "lint:node-version": "pnpm exec node node/scripts/verify-node-version-sync.ts",
    "lint:knip": "cross-env IS_KNIP_RUNNING=true knip --no-progress",
    "lint:tsc": "tsc --build",
    "lint:eslint": "eslint --max-warnings=0",
    "lint:prettier": "prettier --check --log-level=warn .",
    "lint:success-message": "pnpm exec node node/scripts/cli-print-message.ts --type=success --title=\"All linting checks completed successfully.\"",
    "fix": "run-s --continue-on-error fix:*",
    "fix:eslint": "eslint --fix",
    "fix:prettier": "prettier --write --log-level=warn .",
    "fix:complete-message": "pnpm exec node node/scripts/cli-print-message.ts --type=info --title=\"All fixing tasks completed, please review the output above.\"",
    "eslint:inspector": "eslint-config-inspector",
    "eslint:audit": "cross-env SORT_BY=warnings eslint --config=eslint.config.audit.ts --format=summary",
    "eslint:audit:inspector": "eslint-config-inspector --config=eslint.config.audit.ts"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "memoize": "^10.2.0",
    "next": "^16.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remeda": "^2.33.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@commitlint/types": "^20.2.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@eslint-react/eslint-plugin": "^2.5.0",
    "@eslint/config-inspector": "^1.4.2",
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.1.1",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tsconfig/next": "^2.0.5",
    "@tsconfig/node-ts": "^23.6.2",
    "@tsconfig/node24": "^24.0.3",
    "@tsconfig/strictest": "^2.0.8",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/utils": "^8.51.0",
    "cross-env": "^10.1.0",
    "es-module-lexer": "^2.0.0",
    "eslint": "^9.39.2",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-summary": "^2.0.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-command": "^3.4.0",
    "eslint-plugin-depend": "^1.4.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsonc": "^2.21.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-tsdoc": "^0.5.0",
    "eslint-plugin-unicorn": "^62.0.0",
    "handlebars": "^4.7.8",
    "husky": "^9.1.7",
    "json-schema-to-ts": "^3.1.1",
    "jsonc-eslint-parser": "^2.4.2",
    "knip": "^5.79.0",
    "minimatch": "^10.1.1",
    "nano-staged": "^0.9.0",
    "npm-run-all2": "^8.0.4",
    "only-allow": "^1.2.2",
    "p-map": "^7.0.4",
    "pkg-types": "^2.3.0",
    "postcss": "^8.5.6",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.7.4",
    "prettier-plugin-jsdoc": "^1.8.0",
    "tailwindcss": "^4.1.18",
    "tinyexec": "^1.0.2",
    "tinyglobby": "^0.2.15",
    "ts-command-line-args": "^2.5.1",
    "type-fest": "^5.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.4"
  }
}
